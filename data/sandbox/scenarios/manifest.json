{
  "version": "1.0.0",
  "scenarios": [
    {
      "scenarioId": "switch-to-stress",
      "label": "切换到高压力用户",
      "description": "从健康用户切换到高压力用户",
      "type": "profile_switch",
      "payload": { "profileId": "profile-c" }
    },
    {
      "scenarioId": "switch-to-healthy",
      "label": "切换到健康用户",
      "description": "从任意用户切换到健康基准用户",
      "type": "profile_switch",
      "payload": { "profileId": "profile-a" }
    },
    {
      "scenarioId": "inject-late-night",
      "label": "注入深夜活动事件",
      "description": "模拟深夜加班事件",
      "type": "event_inject",
      "payload": {
        "eventType": "late_night_work",
        "data": { "endTime": "03:00" }
      }
    },
    {
      "scenarioId": "inject-illness",
      "label": "注入生病事件",
      "description": "模拟感冒发烧场景",
      "type": "event_inject",
      "payload": {
        "eventType": "illness",
        "data": { "symptoms": ["fever", "fatigue"], "temperature": 38.5 }
      }
    },
    {
      "scenarioId": "override-hrv-drop",
      "label": "HRV 急剧下降",
      "description": "覆盖最近 3 天的 HRV 数据为低值",
      "type": "metric_override",
      "payload": {
        "metric": "hrv",
        "value": 15,
        "dateRange": { "start": "2026-04-08", "end": "2026-04-10" }
      }
    },
    {
      "scenarioId": "override-sleep-deprived",
      "label": "模拟睡眠剥夺",
      "description": "覆盖最近 3 天的睡眠数据为低值",
      "type": "metric_override",
      "payload": {
        "metric": "sleep.totalMinutes",
        "value": 180,
        "dateRange": { "start": "2026-04-08", "end": "2026-04-10" }
      }
    },
    {
      "scenarioId": "reset-all",
      "label": "重置所有修改",
      "description": "清除所有 override 和注入事件",
      "type": "reset",
      "payload": { "scope": "all" }
    },
    {
      "scenarioId": "timeline-append-meal",
      "label": "追加用餐片段",
      "description": "在当前时间轴追加用餐活动片段",
      "type": "timeline_append",
      "payload": {
        "segmentType": "meal_intake",
        "params": { "mealContext": "breakfast" }
      }
    },
    {
      "scenarioId": "timeline-append-cardio",
      "label": "追加有氧运动片段",
      "description": "在当前时间轴追加 30 分钟有氧运动片段",
      "type": "timeline_append",
      "payload": {
        "segmentType": "steady_cardio",
        "params": { "durationMinutes": 30 }
      }
    },
    {
      "scenarioId": "timeline-append-sedentary",
      "label": "追加久坐片段",
      "description": "在当前时间轴追加 120 分钟久坐片段",
      "type": "timeline_append",
      "payload": {
        "segmentType": "prolonged_sedentary",
        "params": { "durationMinutes": 120 }
      }
    },
    {
      "scenarioId": "timeline-append-walk",
      "label": "追加步行片段",
      "description": "在当前时间轴追加步行活动片段",
      "type": "timeline_append",
      "payload": {
        "segmentType": "walk"
      }
    },
    {
      "scenarioId": "timeline-append-sleep",
      "label": "追加睡眠片段",
      "description": "在当前时间轴追加 480 分钟睡眠片段",
      "type": "timeline_append",
      "payload": {
        "segmentType": "sleep",
        "params": { "durationMinutes": 480 }
      }
    },
    {
      "scenarioId": "sync-app-open",
      "label": "应用打开触发同步",
      "description": "模拟用户打开应用触发的设备同步",
      "type": "sync_trigger",
      "payload": { "trigger": "app_open" }
    },
    {
      "scenarioId": "sync-manual-refresh",
      "label": "手动刷新触发同步",
      "description": "模拟用户手动触发设备同步",
      "type": "sync_trigger",
      "payload": { "trigger": "manual_refresh" }
    },
    {
      "scenarioId": "advance-clock-1h",
      "label": "时间推进 1 小时",
      "description": "将 demo 时钟推进 60 分钟",
      "type": "advance_clock",
      "payload": { "minutes": 60 }
    },
    {
      "scenarioId": "reset-timeline",
      "label": "重置时间轴",
      "description": "重置指定 profile 的时间轴到初始状态",
      "type": "reset_profile_timeline",
      "payload": { "profileId": "profile-a" }
    },
    {
      "scenarioId": "demo-stress-journey",
      "label": "演示压力管理旅程",
      "description": "完整演示流程：切换到压力用户 → 注入事件 → 观察变化 → 恢复",
      "type": "demo_script",
      "steps": [
        {
          "label": "切换到高压力用户",
          "action": "profile_switch",
          "payload": { "profileId": "profile-c" }
        },
        {
          "label": "注入深夜加班事件",
          "action": "event_inject",
          "payload": {
            "eventType": "late_night_work",
            "data": { "endTime": "03:00" }
          }
        },
        {
          "label": "覆盖 HRV 数据显示下降",
          "action": "metric_override",
          "payload": {
            "metric": "hrv",
            "value": 15,
            "dateRange": { "start": "2026-04-08", "end": "2026-04-10" }
          }
        }
      ]
    },
    {
      "scenarioId": "demo-recovery-journey",
      "label": "演示恢复改善旅程",
      "description": "完整演示流程：从压力用户覆盖数据改善 → 切换健康用户对比 → 重置",
      "type": "demo_script",
      "steps": [
        {
          "label": "切换到高压力用户",
          "action": "profile_switch",
          "payload": { "profileId": "profile-c" }
        },
        {
          "label": "覆盖睡眠数据模拟改善",
          "action": "metric_override",
          "payload": {
            "metric": "sleep.totalMinutes",
            "value": 480,
            "dateRange": { "start": "2026-04-05", "end": "2026-04-10" }
          }
        },
        {
          "label": "覆盖压力数据模拟降低",
          "action": "metric_override",
          "payload": {
            "metric": "stress.load",
            "value": 25,
            "dateRange": { "start": "2026-04-08", "end": "2026-04-10" }
          }
        },
        {
          "label": "重置所有修改",
          "action": "reset",
          "payload": { "scope": "all" }
        }
      ]
    },
    {
      "scenarioId": "demo-timeline-day",
      "label": "演示时间轴完整日",
      "description": "完整演示流程：追加睡眠 → 追加用餐 → 同步 → 追加久坐 → 推进时钟 → 同步 → 重置",
      "type": "demo_script",
      "steps": [
        {
          "label": "追加睡眠片段",
          "action": "timeline_append",
          "payload": {
            "segmentType": "sleep",
            "params": { "durationMinutes": 480 }
          }
        },
        {
          "label": "追加早餐片段",
          "action": "timeline_append",
          "payload": {
            "segmentType": "meal_intake",
            "params": { "mealContext": "breakfast" }
          }
        },
        {
          "label": "应用打开触发同步",
          "action": "sync_trigger",
          "payload": { "trigger": "app_open" }
        },
        {
          "label": "追加久坐片段",
          "action": "timeline_append",
          "payload": {
            "segmentType": "prolonged_sedentary",
            "params": { "durationMinutes": 120 }
          }
        },
        {
          "label": "推进时钟 1 小时",
          "action": "advance_clock",
          "payload": { "minutes": 60 }
        },
        {
          "label": "手动刷新触发同步",
          "action": "sync_trigger",
          "payload": { "trigger": "manual_refresh" }
        },
        {
          "label": "重置时间轴",
          "action": "reset_profile_timeline",
          "payload": { "profileId": "profile-a" }
        }
      ]
    }
  ]
}
