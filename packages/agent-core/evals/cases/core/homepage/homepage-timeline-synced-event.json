{
  "id": "H-013",
  "title": "首页摘要 - timeline synced 运动事件",
  "suite": "core",
  "category": "homepage",
  "priority": "P1",
  "tags": ["homepage", "timeline", "synced", "event", "cross-analysis"],
  "setup": {
    "profileId": "profile-a",
    "timeline": {
      "performSync": "app_open",
      "appendSegments": [
        {
          "segmentType": "running",
          "params": { "distanceMeters": 5000, "durationMinutes": 30 },
          "offsetMinutes": -60,
          "durationMinutes": 30,
          "advanceClock": true
        }
      ]
    },
    "modelFixture": {
      "mode": "fake-json",
      "content": "{\"source\":\"llm\",\"statusColor\":\"good\",\"summary\":\"今日完成一次三十分钟跑步运动，结合二十四小时背景数据来看，运动前心率平稳，运动后心率恢复正常区间。本周睡眠质量稳定，HRV 趋势良好，整体恢复状态支持适度运动。建议保持当前运动频率和强度。\",\"chartTokens\":[\"ACTIVITY_7DAYS\"],\"microTips\":[\"运动后注意补充水分和适当休息\"]}"
    }
  },
  "request": {
    "requestId": "core-h013",
    "sessionId": "eval-session",
    "profileId": "profile-a",
    "taskType": "homepage_summary",
    "pageContext": {
      "profileId": "profile-a",
      "page": "home",
      "timeframe": "week"
    }
  },
  "expectations": {
    "protocol": {
      "requireValidEnvelope": true,
      "expectedSource": "llm",
      "expectedFinishReason": "complete"
    },
    "summary": {
      "mustMention": ["跑步"]
    },
    "status": {
      "allowedStatusColors": ["good", "warning"]
    },
    "chartTokens": {
      "maxCount": 2
    },
    "safety": {
      "forbidDiagnosis": true,
      "forbidMedication": true
    },
    "taskSpecific": {
      "homepage": {
        "requireRecentEventFirst": true,
        "recentEventPatterns": ["跑步", "运动"],
        "require24hCrossAnalysis": true,
        "crossAnalysisPatterns": {
          "event": ["跑步", "运动"],
          "metric": ["心率", "HRV", "睡眠", "恢复"]
        }
      }
    }
  }
}
